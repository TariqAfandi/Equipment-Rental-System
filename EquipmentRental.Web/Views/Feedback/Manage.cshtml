@model IEnumerable<rental_System_db.Entities.Feedback>
@{
    ViewData["Title"] = "Manage Feedback";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Manage Feedback</h1>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Equipment</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Rating</th>
                            <th>Comment</th>
                            <th>Visibility</th>
                            <th class="table-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var feedback in Model)
                            {
                                <tr>
                                    <td>@feedback.Id</td>
                                    <td>@feedback.Equipment.Name</td>
                                    <td>@feedback.User.Name</td>
                                    <td>@feedback.FeedbackDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <div class="rating">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= feedback.Rating)
                                                {
                                                    <i class="fas fa-star"></i>
                                                }
                                                else
                                                {
                                                    <i class="far fa-star"></i>
                                                }
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(feedback.Comment))
                                        {
                                            @(feedback.Comment.Length > 50 ? feedback.Comment.Substring(0, 50) + "..." : feedback.Comment)
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic">No comment</span>
                                        }
                                    </td>
                                    <td>
                                        @if (feedback.IsVisible)
                                        {
                                            <span class="badge bg-success">Visible</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Hidden</span>
                                        }
                                    </td>
                                    <td>
                                        <form asp-action="ToggleVisibility" asp-route-id="@feedback.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm @(feedback.IsVisible ? "btn-outline-warning" : "btn-outline-success")">
                                                @if (feedback.IsVisible)
                                                {
                                                    <i class="fas fa-eye-slash me-1"></i>
                                                    <span>Hide</span>
                                                }
                                                else
                                                {
                                                    <i class="fas fa-eye me-1"></i>
                                                    <span>Show</span>
                                                }
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center">No feedback found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>