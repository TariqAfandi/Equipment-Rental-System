@model IEnumerable<rental_System_db.Entities.Feedback>
@{
    ViewData["Title"] = "Feedback";
    var equipmentId = ViewBag.EquipmentId as int?;
    var equipmentName = ViewBag.EquipmentName as string;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            @if (equipmentId.HasValue)
            {
                <span>Feedback for @equipmentName</span>
            }
            else
            {
                <span>Equipment Feedback</span>
            }
        </h1>
        @if (equipmentId.HasValue)
        {
            <a asp-controller="Equipment" asp-action="Details" asp-route-id="@equipmentId" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i> Back to Equipment
            </a>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="row mb-4">
                    <div class="col-lg-6">
                        <div class="d-flex align-items-center">
                            <div class="me-3">
                                <span class="display-4">
                                    @Model.Average(f => f.Rating).ToString("F1")
                                </span>
                                <div class="rating">
                                    @{
                                        double avgRating = Model.Average(f => f.Rating);
                                        for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= Math.Floor(avgRating))
                                            {
                                                <i class="fas fa-star"></i>
                                            }
                                            else if (i - avgRating < 1 && i - avgRating > 0)
                                            {
                                                <i class="fas fa-star-half-alt"></i>
                                            }
                                            else
                                            {
                                                <i class="far fa-star"></i>
                                            }
                                        }
                                    }
                                </div>
                            </div>
                            <div>
                                <div class="text-muted">Based on @Model.Count() reviews</div>
                                <div class="d-flex mt-2">
                                    @for (int i = 5; i >= 1; i--)
                                    {
                                        int count = Model.Count(f => f.Rating == i);
                                        int percentage = Model.Any() ? (count * 100) / Model.Count() : 0;
                                        <div class="me-3">
                                            <div>@i <i class="fas fa-star rating"></i></div>
                                            <div class="progress" style="width: 80px; height: 5px;">
                                                <div class="progress-bar bg-primary" role="progressbar" style="width: @percentage%"></div>
                                            </div>
                                            <small class="text-muted">@count</small>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="row">
                    @foreach (var feedback in Model)
                    {
                        <div class="col-md-6 mb-4">
                            <div class="card h-100">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between mb-2">
                                        <div class="d-flex align-items-center">
                                            <div class="me-3">
                                                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                    <i class="fas fa-user text-primary"></i>
                                                </div>
                                            </div>
                                            <div>
                                                <div class="fw-bold">@feedback.User.Name</div>
                                                <div class="small text-muted">@feedback.FeedbackDate.ToString("yyyy-MM-dd")</div>
                                            </div>
                                        </div>
                                        <div>
                                            <div class="rating">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    if (i <= feedback.Rating)
                                                    {
                                                        <i class="fas fa-star"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="far fa-star"></i>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    @if (!equipmentId.HasValue)
                                    {
                                        <div class="mb-2">
                                            <a asp-controller="Equipment" asp-action="Details" asp-route-id="@feedback.EquipmentId" class="text-decoration-none">
                                                <i class="fas fa-tools me-1"></i> @feedback.Equipment.Name
                                            </a>
                                        </div>
                                    }

                                    @if (!string.IsNullOrEmpty(feedback.Comment))
                                    {
                                        <p class="card-text">@feedback.Comment</p>
                                    }
                                    else
                                    {
                                        <p class="text-muted fst-italic">No comment provided.</p>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    @if (equipmentId.HasValue)
                    {
                        <span>No feedback has been provided for this equipment yet.</span>
                    }
                    else
                    {
                        <span>No feedback has been provided yet.</span>
                    }
                </div>
            }
        </div>
    </div>
</div>