@model EquipmentRental.Web.Models.ViewModels.FeedbackViewModel
@{
    ViewData["Title"] = "Leave Feedback";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Leave Feedback</h1>
        @if (Model.RentalTransactionId.HasValue)
        {
            <a asp-controller="RentalTransaction" asp-action="Details" asp-route-id="@Model.RentalTransactionId" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i> Back to Rental
            </a>
        }
        else
        {
            <a asp-controller="RentalTransaction" asp-action="MyRentals" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i> Back to My Rentals
            </a>
        }
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Rate and Review</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <input type="hidden" asp-for="EquipmentId" />
                        <input type="hidden" asp-for="RentalTransactionId" />
                        
                        @if (!ViewBag.SelectedEquipment)
                        {
                            <div class="mb-4">
                                <label asp-for="EquipmentId" class="form-label required">Equipment</label>
                                <select asp-for="EquipmentId" class="form-select" asp-items="ViewBag.Equipment">
                                    <option value="">-- Select Equipment --</option>
                                </select>
                                <span asp-validation-for="EquipmentId" class="text-danger"></span>
                            </div>
                        }
                        else
                        {
                            <div class="mb-4">
                                <p class="form-label fw-bold">Equipment</p>
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(Model.EquipmentName))
                                    {
                                        <div class="fw-bold fs-5">@Model.EquipmentName</div>
                                    }
                                </div>
                            </div>
                        }
                        
                        <div class="mb-4">
                            <label asp-for="Rating" class="form-label required">Rating</label>
                            <div class="rating-input mb-2">
                                <div class="d-flex">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <div class="me-2">
                                            <span id="star@(i)" class="fs-2 @(i <= Model.Rating ? "fas" : "far") fa-star rating" style="cursor: pointer;" onclick="setRating(@i)"></span>
                                        </div>
                                    }
                                </div>
                                <input type="hidden" asp-for="Rating" id="Rating" />
                            </div>
                            <span asp-validation-for="Rating" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="Comment" class="form-label">Comments (Optional)</label>
                            <textarea asp-for="Comment" class="form-control" rows="5" placeholder="Share your experience with this equipment..."></textarea>
                            <span asp-validation-for="Comment" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane me-2"></i> Submit Feedback
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Rating Guidelines</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="d-flex align-items-center mb-2">
                            <div class="me-2">
                                <i class="fas fa-star rating"></i>
                                <i class="fas fa-star rating"></i>
                                <i class="fas fa-star rating"></i>
                                <i class="fas fa-star rating"></i>
                                <i class="fas fa-star rating"></i>
                            </div>
                            <div class="fw-bold">Excellent (5)</div>
                        </div>
                        <p class="small text-muted">Equipment was in perfect condition, exceeded expectations.</p>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex align-items-center mb-2">
                            <div class="me-2">
                                <i class="fas fa-star rating"></i>
                                <i class="fas fa-star rating"></i>
                                <i class="fas fa-star rating"></i>
                                <i class="fas fa-star rating"></i>
                                <i class="far fa-star rating"></i>
                            </div>
                            <div class="fw-bold">Very Good (4)</div>
                        </div>
                        <p class="small text-muted">Equipment was in great condition with minor issues.</p>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex align-items-center mb-2">
                            <div class="me-2">
                                <i class="fas fa-star rating"></i>
                                <i class="fas fa-star rating"></i>
                                <i class="fas fa-star rating"></i>
                                <i class="far fa-star rating"></i>
                                <i class="far fa-star rating"></i>
                            </div>
                            <div class="fw-bold">Good (3)</div>
                        </div>
                        <p class="small text-muted">Equipment was functional but had some noticeable issues.</p>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex align-items-center mb-2">
                            <div class="me-2">
                                <i class="fas fa-star rating"></i>
                                <i class="fas fa-star rating"></i>
                                <i class="far fa-star rating"></i>
                                <i class="far fa-star rating"></i>
                                <i class="far fa-star rating"></i>
                            </div>
                            <div class="fw-bold">Fair (2)</div>
                        </div>
                        <p class="small text-muted">Equipment had significant issues but was still usable.</p>
                    </div>

                    <div>
                        <div class="d-flex align-items-center mb-2">
                            <div class="me-2">
                                <i class="fas fa-star rating"></i>
                                <i class="far fa-star rating"></i>
                                <i class="far fa-star rating"></i>
                                <i class="far fa-star rating"></i>
                                <i class="far fa-star rating"></i>
                            </div>
                            <div class="fw-bold">Poor (1)</div>
                        </div>
                        <p class="small text-muted">Equipment was in terrible condition or didn't work properly.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function setRating(rating) {
            document.getElementById('Rating').value = rating;

            // Update star colors
            for (let i = 1; i <= 5; i++) {
                const star = document.getElementById('star' + i);
                if (i <= rating) {
                    star.classList.remove('far');
                    star.classList.add('fas');
                } else {
                    star.classList.remove('fas');
                    star.classList.add('far');
                }
            }
        }
    </script>
}