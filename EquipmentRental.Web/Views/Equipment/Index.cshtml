@model IEnumerable<rental_System_db.Entities.Equipment>
@{
    ViewData["Title"] = "Equipment";
    var isStaff = Context.Session.GetString("UserRole") == "Administrator" || Context.Session.GetString("UserRole") == "RentalManager";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Equipment</h1>
    @if (isStaff)
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i> Add New Equipment
        </a>
    }
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0">Filter Equipment</h5>
    </div>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Category</label>
                    <select name="categoryId" class="form-select" asp-items="ViewBag.Categories">
                        <option value="">All Categories</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Availability</label>
                    <select name="availabilityFilter" class="form-select" asp-items="ViewBag.AvailabilityOptions">
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Search</label>
                    <div class="input-group">
                        <input type="text" name="searchString" class="form-control" placeholder="Search..." value="@ViewBag.SearchString">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="row">
    @if (Model != null && Model.Any())
    {
        foreach (var equipment in Model)
        {
            <div class="col-md-4 col-lg-3 mb-4">
                <div class="card equipment-card h-100">
                    @if (!string.IsNullOrEmpty(equipment.ImageUrl))
                    {
                        <img src="@equipment.ImageUrl" class="card-img-top equipment-image" alt="@equipment.Name">
                    }
                    else
                    {
                        <div class="card-img-top equipment-image bg-light d-flex align-items-center justify-content-center">
                            <i class="fas fa-tools fa-4x text-secondary"></i>
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="card-title">@equipment.Name</h5>
                        <p class="card-text small text-muted">@equipment.Category?.Name</p>
                        <p class="card-text">
                            @(equipment.Description?.Length > 100
                                ? equipment.Description.Substring(0, 100) + "..."
                                : equipment.Description)
                        </p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="h5 mb-0 text-primary">$@equipment.RentalPrice.ToString("F2")</span>
                            <span class="badge status-@equipment.AvailabilityStatus">@equipment.AvailabilityStatus</span>
                        </div>
                        <div class="mt-3">
                            <a asp-action="Details" asp-route-id="@equipment.Id" class="btn btn-outline-primary w-100">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i> No equipment found.
            </div>
        </div>
    }
</div>