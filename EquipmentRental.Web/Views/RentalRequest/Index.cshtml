@model IEnumerable<rental_System_db.Entities.RentalRequest>
@{
    ViewData["Title"] = "Rental Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Rental Requests</h1>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0">Filter Requests</h5>
    </div>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select name="statusFilter" class="form-select" asp-items="ViewBag.StatusOptions">
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Start Date</label>
                    <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate?.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-3">
                    <label class="form-label">End Date</label>
                    <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate?.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Search</label>
                    <div class="input-group">
                        <input type="text" name="searchString" class="form-control" placeholder="Search..." value="@ViewBag.SearchString">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Customer</th>
                        <th>Equipment</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th>Request Date</th>
                        <th class="table-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var request in Model)
                        {
                            <tr>
                                <td>@request.Id</td>
                                <td>@request.User?.Name</td>
                                <td>@request.Equipment?.Name</td>
                                <td>@request.RentalStartDate.ToString("yyyy-MM-dd")</td>
                                <td>@request.RentalEndDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    @switch (request.Status)
                                    {
                                        case "Pending":
                                            <span class="badge bg-info">Pending</span>
                                            break;
                                        case "Approved":
                                            <span class="badge bg-success">Approved</span>
                                            break;
                                        case "Rejected":
                                            <span class="badge bg-danger">Rejected</span>
                                            break;
                                        case "Completed":
                                            <span class="badge bg-secondary">Completed</span>
                                            break;
                                        case "Cancelled":
                                            <span class="badge bg-warning">Cancelled</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">@request.Status</span>
                                            break;
                                    }
                                </td>
                                <td>@request.RequestDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@request.Id" class="btn btn-sm btn-outline-info">
                                            <i class="fas fa-info-circle"></i> Details
                                        </a>
                                        @if (request.Status == "Pending")
                                        {
                                            <a asp-action="Edit" asp-route-id="@request.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-edit"></i> Process
                                            </a>
                                        }
                                        @if (request.Status == "Approved" && request.RentalTransaction == null)
                                        {
                                            <a asp-controller="RentalTransaction" asp-action="Create" asp-route-requestId="@request.Id" class="btn btn-sm btn-outline-success">
                                                <i class="fas fa-check-circle"></i> Checkout
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center">No rental requests found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>