@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container text-center py-5">
    <h1 class="text-danger display-4">Error</h1>
    <h2 class="mb-4">An error occurred while processing your request.</h2>

    @if (Model.ShowRequestId)
    {
        <p>
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <div class="my-5">
        <div class="card shadow-sm mb-4 mx-auto" style="max-width: 500px;">
            <div class="card-body">
                <h5 class="card-title">What should I do?</h5>
                <ul class="text-start">
                    <li>Try refreshing the page</li>
                    <li>Clear your browser cache and cookies</li>
                    <li>Try again later</li>
                    <li>Contact our support team if the problem persists</li>
                </ul>
                <div class="mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                        <i class="fas fa-home me-2"></i> Return to Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>