@model rental_System_db.Entities.ReturnRecord
@{
    ViewData["Title"] = "Return Record Details";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Return Record Details</h1>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i> Back to List
        </a>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Return Details</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Return ID</label>
                                <div>#@Model.Id</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Return Date</label>
                                <div>@Model.ReturnDate.ToString("yyyy-MM-dd")</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Return Condition</label>
                                <div>
                                    <span class="badge @(Model.ReturnCondition == "Good" ? "bg-success" : Model.ReturnCondition == "Damaged" ? "bg-warning" : "bg-danger")">
                                        @Model.ReturnCondition
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Processed By</label>
                                <div>@Model.ProcessedByUser.Name</div>
                            </div>
                        </div>

                        @if (Model.LateFee > 0)
                        {
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Late Fee</label>
                                    <div class="text-danger">$@Model.LateFee?.ToString("F2")</div>
                                </div>
                            </div>
                        }

                        @if (Model.DamageFee > 0)
                        {
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Damage Fee</label>
                                    <div class="text-danger">$@Model.DamageFee?.ToString("F2")</div>
                                </div>
                            </div>
                        }

                        @if (Model.RefundAmount > 0)
                        {
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Refund Amount</label>
                                    <div class="text-success">$@Model.RefundAmount?.ToString("F2")</div>
                                </div>
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <div class="mt-3">
                            <label class="form-label fw-bold">Notes</label>
                            <div class="p-3 bg-light rounded">@Model.Notes</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Rental Information</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Transaction ID</label>
                        <div>#@Model.RentalTransaction.Id</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Equipment</label>
                        <div>@Model.RentalTransaction.Equipment.Name</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Customer</label>
                        <div>@Model.RentalTransaction.User.Name</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Rental Period</label>
                        <div>
                            @Model.RentalTransaction.ActualStartDate.ToString("yyyy-MM-dd") to @Model.RentalTransaction.ExpectedReturnDate.ToString("yyyy-MM-dd")
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Rental Fee</label>
                        <div>$@Model.RentalTransaction.RentalFee.ToString("F2")</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Deposit</label>
                        <div>$@Model.RentalTransaction.DepositAmount?.ToString("F2")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>