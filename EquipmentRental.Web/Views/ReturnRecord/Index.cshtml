@model IEnumerable<rental_System_db.Entities.ReturnRecord>
@{
    ViewData["Title"] = "Return Records";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Return Records</h1>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Filter Returns</h5>
        </div>
        <div class="card-body">
            <form method="get" asp-action="Index">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Condition</label>
                        <select name="conditionFilter" class="form-select">
                            <option value="">All Conditions</option>
                            @foreach (var condition in ViewBag.ConditionOptions)
                            {
                                <option value="@condition" selected="@(ViewBag.ConditionFilter == condition)">@condition</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Search</label>
                        <div class="input-group">
                            <input type="text" name="searchString" class="form-control" placeholder="Search by customer or equipment..." value="@ViewBag.SearchString">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-filter me-2"></i> Apply Filters
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Equipment</th>
                            <th>Customer</th>
                            <th>Return Date</th>
                            <th>Condition</th>
                            <th>Late Fee</th>
                            <th>Damage Fee</th>
                            <th>Refund</th>
                            <th>Processed By</th>
                            <th class="table-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var returnRecord in Model)
                            {
                                <tr>
                                    <td>@returnRecord.Id</td>
                                    <td>@returnRecord.RentalTransaction.Equipment.Name</td>
                                    <td>@returnRecord.RentalTransaction.User.Name</td>
                                    <td>@returnRecord.ReturnDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <span class="badge @(returnRecord.ReturnCondition == "Good" ? "bg-success" : returnRecord.ReturnCondition == "Damaged" ? "bg-warning" : "bg-danger")">
                                            @returnRecord.ReturnCondition
                                        </span>
                                    </td>
                                    <td>
                                        @if (returnRecord.LateFee > 0)
                                        {
                                            <span class="text-danger">$@returnRecord.LateFee?.ToString("F2")</span>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (returnRecord.DamageFee > 0)
                                        {
                                            <span class="text-danger">$@returnRecord.DamageFee?.ToString("F2")</span>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (returnRecord.RefundAmount > 0)
                                        {
                                            <span class="text-success">$@returnRecord.RefundAmount?.ToString("F2")</span>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td>@returnRecord.ProcessedByUser.Name</td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@returnRecord.Id" class="btn btn-sm btn-outline-info">
                                            <i class="fas fa-info-circle"></i> Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="10" class="text-center">No return records found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
