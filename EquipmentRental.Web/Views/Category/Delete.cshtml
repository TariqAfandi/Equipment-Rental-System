@model rental_System_db.Entities.Category
@{
    ViewData["Title"] = "Delete Category";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Delete Category</h1>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i> Back to List
    </a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body bg-light">
        <h3 class="text-danger">Are you sure you want to delete this category?</h3>
        <p>This action cannot be undone.</p>
    </div>
</div>

@if (ViewBag.HasEquipment == true)
{
    <div class="alert alert-danger">
        <h5 class="alert-heading"><i class="fas fa-exclamation-triangle me-2"></i> Warning!</h5>
        <p>This category contains @ViewBag.EquipmentCount equipment items. You cannot delete it until all equipment is moved to another category or deleted.</p>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.Description) ? "-" : Model.Description)</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactive</span>
                    }
                </dd>

                <dt class="col-sm-3">Created At</dt>
                <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
            </dl>

            <form asp-action="Delete" class="mt-4">
                <input type="hidden" asp-for="Id" />
                <div class="text-center">
                    <button type="submit" class="btn btn-danger" @(ViewBag.HasEquipment == true ? "disabled" : "")>
                        <i class="fas fa-trash me-2"></i> Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
}